# Required
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Host ports (optional). If unset, ./start picks free random ports.
# AGENT_PORT=18080
# REDIS_PORT=16379

# Public URLs (optional). ./start derives these from the chosen ports when unset.
# PUBLIC_BASE_URL=http://localhost:18080
# PUBLIC_REDIS_URL=redis://localhost:16379/0

# Copy to .env and fill in values:
#   cp .env.example .env

# --- Required ---
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Same API key as chat — used to embed programs/*/knowledge into Qdrant (RAG).
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Max characters for a single user message (input + transcript retention).
# Over this length: friendly "please summarize" reply; body is not stored.
# MAX_MESSAGE_CHARS=1500

# --- Host API port (Docker Compose via ./start) ---
# Optional. If unset, ./start allocates a free random port.
AGENT_PORT=18080

# --- Redis (optional) ---
# If REDIS_URL is unset, ./start spawns an embedded Redis container and
# publishes it on REDIS_PORT (random if REDIS_PORT unset).
# If REDIS_URL is set, that Redis is used and no Redis container is started.
# REDIS_URL=redis://localhost:6379/0
REDIS_PORT=16379

# --- Qdrant vector DB (optional external) ---
# If QDRANT_URL is unset, ./start spawns embedded Qdrant (profile embedded-qdrant).
# If set, that instance is used and no Qdrant container is started.
# QDRANT_URL=http://localhost:6333
QDRANT_PORT=16333

# Host-facing URLs for logs / health / CLI (optional; ./start fills defaults).
# PUBLIC_BASE_URL=http://localhost:18080
# PUBLIC_REDIS_URL=redis://localhost:16379/0
# PUBLIC_QDRANT_URL=http://localhost:16333

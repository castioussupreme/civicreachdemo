#!/usr/bin/env bash
# Install git pre-commit hooks (Husky equivalent for Python).
set -euo pipefail
cd "$(dirname "$0")"

if [[ ! -d .venv ]]; then
  python3 -m venv .venv
fi
# shellcheck disable=SC1091
source .venv/bin/activate

pip install -q -e ".[dev]"
pre-commit install
# pre-push re-runs the same suite for extra safety
pre-commit install --hook-type pre-push 2>/dev/null || true

echo "Pre-commit hooks installed."
echo "  on commit: trailing/EOF checks + ruff lint/format + mypy + vulture + pytest"
echo "  manual:    pre-commit run --all-files"
